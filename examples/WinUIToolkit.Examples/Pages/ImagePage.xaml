<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUIToolkit.Examples.Pages.ImagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="ImageManipulationHelper" FontSize="24" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Pick a local image to load, then apply resize, crop, rotate, brightness, grayscale, and invert." />

            <Button Content="Pick image" Click="Pick_Click" />

            <TextBlock Text="Source" />
            <Image x:Name="SourceImage" MaxWidth="320" MaxHeight="240" Stretch="Uniform" />

            <TextBlock Text="Filters" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Content="Grayscale" Click="Grayscale_Click" />
                <Button Content="Invert" Click="Invert_Click" />
                <Button Content="Brighten x1.5" Click="Brighten_Click" />
            </StackPanel>

            <TextBlock Text="Resize" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <NumberBox x:Name="ResizeW" Header="Width" Value="128" SpinButtonPlacementMode="Inline" />
                <NumberBox x:Name="ResizeH" Header="Height" Value="128" SpinButtonPlacementMode="Inline" />
                <Button Content="Resize" Click="Resize_Click" VerticalAlignment="Bottom" />
            </StackPanel>

            <TextBlock Text="Rotate" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="90°" Click="Rotate_Click" Tag="90" />
                <Button Content="180°" Click="Rotate_Click" Tag="180" />
                <Button Content="270°" Click="Rotate_Click" Tag="270" />
            </StackPanel>

            <TextBlock Text="Output" />
            <Image x:Name="OutputImage" MaxWidth="320" MaxHeight="240" Stretch="Uniform" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
