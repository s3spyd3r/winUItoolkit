<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUIToolkit.Examples.Pages.HttpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="ServicesHelper" FontSize="24" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Text="Issues a typed HTTP GET against the configured base address. The default endpoint hits httpbin.org, which echoes the request as JSON." />

            <TextBox x:Name="Server" Header="ServerAddress" Text="https://httpbin.org/" />
            <TextBox x:Name="Endpoint" Header="Endpoint" Text="uuid" />

            <Button Content="GET" Click="Get_Click" />

            <TextBlock Text="Response" FontWeight="SemiBold" />
            <TextBox x:Name="Response" AcceptsReturn="True" TextWrapping="Wrap" Height="200" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
