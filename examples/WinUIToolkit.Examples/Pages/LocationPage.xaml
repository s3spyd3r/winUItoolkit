<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUIToolkit.Examples.Pages.LocationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="520" HorizontalAlignment="Left">
            <TextBlock Text="LocationHelper" FontSize="24" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Text="Reads the current position via Geolocator, plus distance/unit conversion helpers." />

            <Button Content="Get current position" Click="GetPosition_Click" />
            <TextBlock x:Name="Position" TextWrapping="Wrap" />

            <TextBlock Text="Distance" FontWeight="SemiBold" Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <NumberBox x:Name="Lat1" Header="Lat 1" Value="40.7128" SpinButtonPlacementMode="Inline" />
                <NumberBox x:Name="Lon1" Header="Lon 1" Value="-74.0060" SpinButtonPlacementMode="Inline" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <NumberBox x:Name="Lat2" Header="Lat 2" Value="51.5074" SpinButtonPlacementMode="Inline" />
                <NumberBox x:Name="Lon2" Header="Lon 2" Value="-0.1278" SpinButtonPlacementMode="Inline" />
            </StackPanel>
            <Button Content="Compute distance" Click="Distance_Click" />
            <TextBlock x:Name="Distance" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
