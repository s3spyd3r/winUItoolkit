<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUIToolkit.Examples.Pages.RetryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="520" HorizontalAlignment="Left">
            <TextBlock Text="RetryPolicyHelper" FontSize="24" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Text="Executes a flaky operation up to N times with exponential backoff. Below, the operation fails the first 2 attempts and succeeds on the 3rd." />

            <Button Content="Run flaky operation" Click="Run_Click" />
            <TextBlock x:Name="Result" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
