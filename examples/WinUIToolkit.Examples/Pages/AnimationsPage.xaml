<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUIToolkit.Examples.Pages.AnimationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="CustomAnimations" FontSize="24" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Each button triggers one of the storyboard helpers. The target is the orange square below; visibility/opacity/transforms are driven by the helper." />

            <Border x:Name="TargetBox"
                    Width="120" Height="120"
                    Background="DarkOrange"
                    CornerRadius="8"
                    Margin="0,12,0,12" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Content="Show" Click="Show_Click" />
                <Button Content="Hide" Click="Hide_Click" />
                <Button Content="Slide In" Click="SlideIn_Click" />
                <Button Content="Scale In" Click="ScaleIn_Click" />
                <Button Content="Shake" Click="Shake_Click" />
                <Button Content="Flip" Click="Flip_Click" />
                <Button Content="Toggle" Click="Toggle_Click" />
            </StackPanel>

            <TextBlock Text="Source" FontWeight="SemiBold" Margin="0,16,0,0" />
            <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Animations\CustomAnimations.cs - fade, slide, scale, shake, flip + RunStoryboardAsync helper." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
