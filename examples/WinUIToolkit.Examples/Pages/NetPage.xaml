<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinUIToolkit.Examples.Pages.NetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="520" HorizontalAlignment="Left">
            <TextBlock Text="NetHelper" FontSize="24" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Text="Quick system-level connectivity check." />
            <Button Content="Check connection" Click="Check_Click" />
            <TextBlock x:Name="Result" FontSize="16" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
